# Centrum Bolotova — production rewrite rules (Apache / LiteSpeed on HostCreators).
# GitHub Pages ignores this file; it only takes effect on the SFTP-deployed host.

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Clean API URLs: /api/<name>  ->  /api/<name>.php  (e.g. /api/order, /api/stripe-webhook).
  # Only rewrites when the request isn't a real file/dir AND the .php target exists,
  # so static files and non-existent paths are untouched. The .php URLs still work directly.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{DOCUMENT_ROOT}/api/$1.php -f
  RewriteRule ^api/([a-z0-9_-]+)/?$ api/$1.php [L]
</IfModule>
